# 服务端口
PORT=3000

# 数据库
DATABASE_URL="mysql://root:password@localhost:3306/yours_db"

# Redis
REDIS_URL="redis://localhost:6379"

# 微信小程序
WX_APPID="wx0000000000000000"
WX_SECRET="your_wx_secret"

# JWT
JWT_SECRET="your_jwt_secret_key_change_in_production"
JWT_EXPIRES_IN="7d"

# 腾讯云 COS
COS_SECRET_ID="your_cos_secret_id"
COS_SECRET_KEY="your_cos_secret_key"
COS_BUCKET="yours-1234567890"
COS_REGION="ap-guangzhou"

# AI 3D 生成 — Tripo3D
TRIPO_API_KEY="your_tripo_api_key"
TRIPO_API_URL="https://api.tripo3d.ai"

# AI 3D 生成 — 腾讯混元3D
HUNYUAN_SECRET_ID="your_tencent_secret_id"
HUNYUAN_SECRET_KEY="your_tencent_secret_key"
HUNYUAN_REGION="ap-guangzhou"

# 默认AI引擎（tripo 或 hunyuan）
DEFAULT_AI_ENGINE="tripo"
