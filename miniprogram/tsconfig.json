{
  "compilerOptions": {
    "strict": false,
    "target": "ES2017",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2017"],
    "outDir": "./",
    "rootDir": "./",
    "typeRoots": [
      "./typings",
      "./node_modules"
    ],
    "types": [],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "miniprogram_npm"
  ],
  "files": [
    "node_modules/miniprogram-api-typings/index.d.ts"
  ]
}
