<!-- 3D模型预览页 — Yours·凝刻 -->
<view class="preview-page">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <text class="back-icon">←</text>
        <text class="back-text">我的手办</text>
      </view>
      <view class="nav-share" bindtap="onShareTap">
        <text>📤</text>
      </view>
    </view>
  </view>

  <!-- 3D 模型渲染区域 -->
  <view class="model-area" style="padding-top: {{navHeight}}px;">

    <!-- 方案1: 有 modelUrl 时用 web-view 加载真 3D 预览 -->
    <web-view 
      wx:if="{{!loading && !loadError && modelUrl && viewerUrl}}"
      src="{{viewerUrl}}"
      class="model-webview"
    />

    <!-- 方案2: 降级为预览图（无 modelUrl 时） -->
    <view class="model-preview-container" 
      wx:if="{{!loading && !loadError && !modelUrl}}"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    >
      <view class="platform-shadow"></view>
      <view class="model-image-wrapper" style="transform: perspective(800px) rotateX({{rotationX}}deg) rotateY({{rotationY}}deg) scale({{scale}});">
        <image 
          wx:if="{{previewUrl}}"
          class="model-image" 
          src="{{previewUrl}}" 
          mode="aspectFit"
        />
        <image 
          wx:elif="{{originalPhotoUrl}}"
          class="model-image" 
          src="{{originalPhotoUrl}}" 
          mode="aspectFit"
        />
        <view wx:else class="model-placeholder">
          <text class="placeholder-icon">🎭</text>
          <text class="placeholder-text">模型预览图加载中</text>
        </view>
      </view>
      <view class="rotate-indicator" wx:if="{{autoRotate}}">
        <text class="rotate-dot">●</text>
        <text class="rotate-label">自动旋转中</text>
      </view>
    </view>

    <!-- Loading 骨架屏 -->
    <view class="loading-overlay" wx:if="{{loading}}">
      <view class="loading-spinner">
        <view class="spinner-ring"></view>
      </view>
      <text class="loading-text">模型加载中...</text>
      <view class="loading-progress" wx:if="{{loadProgress > 0}}">
        <view class="progress-bar-bg">
          <view class="progress-bar-fill" style="width: {{loadProgress}}%;"></view>
        </view>
        <text class="progress-num">{{loadProgress}}%</text>
      </view>
    </view>

    <!-- 加载失败 -->
    <view class="error-overlay" wx:if="{{loadError}}">
      <text class="error-emoji">😢</text>
      <text class="error-title">模型加载失败</text>
      <text class="error-desc">{{loadErrorMsg}}</text>
      <view class="error-btn" bindtap="reloadModel">
        <text>重新加载</text>
      </view>
    </view>
  </view>

  <!-- 首次手势引导蒙层 -->
  <view class="guide-overlay" wx:if="{{showGuide}}" bindtap="dismissGuide">
    <view class="guide-content">
      <view class="guide-item {{guideStep >= 1 ? 'active' : ''}}">
        <text class="guide-icon">🔄</text>
        <text class="guide-label">滑动旋转，360°查看</text>
      </view>
      <view class="guide-item {{guideStep >= 2 ? 'active' : ''}}">
        <text class="guide-icon">🔍</text>
        <text class="guide-label">双指缩放，查看细节</text>
      </view>
      <view class="guide-item {{guideStep >= 3 ? 'active' : ''}}">
        <text class="guide-icon">👆</text>
        <text class="guide-label">双击重置视角</text>
      </view>
      <view class="guide-skip">
        <text>点击任意处开始体验</text>
      </view>
    </view>
  </view>

  <!-- 底部操作区（web-view 模式下不显示，因为 web-view 会覆盖全部） -->
  <view class="bottom-actions safe-area-bottom" wx:if="{{!loading && !loadError && !modelUrl}}">
    <view class="action-row">
      <view class="action-item" bindtap="onExportModel">
        <text class="action-icon">📥</text>
        <text class="action-label">导出模型</text>
      </view>
      <view class="action-item" bindtap="onRegenerate">
        <text class="action-icon">🔄</text>
        <text class="action-label">重新生成</text>
      </view>
    </view>
    <view class="main-btn" bindtap="goToCustomize">
      <text>✨ 定制我的手办</text>
    </view>
  </view>

  <!-- 3D 模式底部浮层操作 -->
  <view class="float-actions safe-area-bottom" wx:if="{{!loading && !loadError && modelUrl}}">
    <view class="float-action-bar">
      <view class="float-btn secondary" bindtap="onExportModel">
        <text>📥 导出</text>
      </view>
      <view class="float-btn secondary" bindtap="onRegenerate">
        <text>🔄 重做</text>
      </view>
      <view class="float-btn primary" bindtap="goToCustomize">
        <text>✨ 定制手办</text>
      </view>
    </view>
  </view>

  <!-- 分享面板 -->
  <view class="share-mask" wx:if="{{showSharePanel}}" bindtap="closeSharePanel">
    <view class="share-panel" catchtap="">
      <text class="share-title">分享手办</text>
      <view class="share-options">
        <button class="share-item" open-type="share">
          <text class="share-item-icon">💬</text>
          <text class="share-item-label">发送给好友</text>
        </button>
        <view class="share-item" bindtap="generatePoster">
          <text class="share-item-icon">🖼</text>
          <text class="share-item-label">生成海报</text>
        </view>
      </view>
      <view class="share-cancel" bindtap="closeSharePanel">
        <text>取消</text>
      </view>
    </view>
  </view>

  <!-- 导出弹窗 -->
  <view class="share-mask" wx:if="{{showExportPanel}}" bindtap="closeExportPanel">
    <view class="share-panel" catchtap="">
      <text class="share-title">导出 3D 模型文件</text>
      <view class="export-info">
        <text class="export-line">📁 模型格式：glTF (.glb)</text>
        <text class="export-line">📊 文件大小：约 {{modelFileSize}}MB</text>
      </view>
      <view class="share-options">
        <view class="share-item" bindtap="saveToPhone">
          <text class="share-item-icon">💾</text>
          <text class="share-item-label">保存到手机</text>
        </view>
        <view class="share-item" bindtap="sendViaWechat">
          <text class="share-item-icon">📤</text>
          <text class="share-item-label">通过微信发送</text>
        </view>
      </view>
      <view class="share-cancel" bindtap="closeExportPanel">
        <text>取消</text>
      </view>
    </view>
  </view>
</view>
