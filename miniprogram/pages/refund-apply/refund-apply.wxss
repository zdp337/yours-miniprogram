/* 退款申请页样式 — Yours·凝刻 */

.refund-page {
  height: 100vh;
  background: var(--bg-color);
  position: relative;
}

.scroll-area {
  height: 100vh;
  padding: var(--spacing-md);
}

.section {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: var(--spacing-md);
  color: var(--text-primary);
}

/* 订单信息 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.info-value.price {
  color: var(--accent-color);
  font-weight: 600;
}

/* 退款原因 */
.reason-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.reason-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 8rpx 0;
}

.reason-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border-color);
  margin-right: var(--spacing-md);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.radio-checked {
  border-color: var(--brand-color);
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--brand-color);
}

/* 退款说明 */
.desc-input {
  width: 100%;
  height: 160rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm);
  font-size: 26rpx;
  box-sizing: border-box;
}

.desc-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 8rpx;
}

/* 照片上传 */
.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.photo-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  position: relative;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-bottom-left-radius: var(--radius-sm);
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--border-color);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.add-icon {
  font-size: 48rpx;
  color: var(--text-placeholder);
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 4rpx;
}

.photo-tip {
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: var(--spacing-sm);
}

/* 退款须知 */
.notice-section {
  background: #FFF8E1;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
}

.notice-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 底部提交 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-white);
  padding: var(--spacing-md) var(--spacing-lg);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: var(--brand-color);
  border-radius: var(--radius-round);
  display: flex;
  justify-content: center;
  align-items: center;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
}

.submit-disabled {
  background: #CCCCCC;
  pointer-events: none;
}
