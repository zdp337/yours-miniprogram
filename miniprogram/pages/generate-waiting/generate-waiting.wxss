/* AI生成等待页样式 — Yours·凝刻 */

.waiting-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A2E 0%, #16213E 50%, #0F3460 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  padding-top: 180rpx;
}

/* 动画区域 */
.animation-section {
  margin-bottom: 64rpx;
}

.lottie-wrap {
  width: 280rpx;
  height: 280rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pulse-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 107, 53, 0.3);
  animation: pulse 3s ease-out infinite;
}

.ring-1 {
  width: 200rpx;
  height: 200rpx;
  animation-delay: 0s;
}

.ring-2 {
  width: 240rpx;
  height: 240rpx;
  animation-delay: 0.8s;
}

.ring-3 {
  width: 280rpx;
  height: 280rpx;
  animation-delay: 1.6s;
}

@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(1.3);
    opacity: 0;
  }
}

.center-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F66 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(255, 107, 53, 0.4);
  z-index: 1;
}

.center-emoji {
  font-size: 64rpx;
}

/* 状态区 */
.status-section {
  text-align: center;
  width: 100%;
  margin-bottom: 48rpx;
}

.status-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 32rpx;
}

.progress-wrap {
  width: 100%;
  padding: 0 24rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8F66 100%);
  transition: width 1s ease;
}

.progress-fill.animating {
  animation: shimmer 2s ease infinite;
}

@keyframes shimmer {
  0% { opacity: 1; }
  50% { opacity: 0.7; }
  100% { opacity: 1; }
}

.progress-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 完成态 */
.complete-section {
  margin-top: 32rpx;
}

.view-btn {
  width: 480rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F66 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.4);
}

.view-btn::after {
  border: none;
}

.breathing {
  animation: breathing 2s ease-in-out infinite;
}

@keyframes breathing {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

/* 等待中操作 */
.waiting-actions {
  width: 100%;
  margin-top: 32rpx;
}

.tip-card {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-content {
  display: flex;
  flex-direction: column;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.tip-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
}

.notify-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: rgba(64, 150, 255, 0.2);
  color: #4096FF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid rgba(64, 150, 255, 0.3);
  margin-bottom: 24rpx;
}

.notify-btn::after {
  border: none;
}

.subscribed-text {
  text-align: center;
  margin-bottom: 24rpx;
}

.subscribed-text text {
  font-size: 28rpx;
  color: #07C160;
}

.go-home-link {
  text-align: center;
  padding: 16rpx 0;
}

.go-home-link text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}
