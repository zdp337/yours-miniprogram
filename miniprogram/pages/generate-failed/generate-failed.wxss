/* 生成失败页样式 — Yours·凝刻 */

.failed-page {
  min-height: 100vh;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 0;
}

/* 失败图标 */
.icon-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.fail-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F5F5F5 0%, #E8E8E8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.fail-emoji {
  font-size: 80rpx;
}

.fail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

/* 失败原因 */
.reason-card {
  width: 100%;
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.reason-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.reason-content {
  display: flex;
  flex-direction: column;
}

.reason-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.reason-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 操作按钮 */
.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.btn-retry {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #333333;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.btn-retry::after {
  border: none;
}

.btn-retry.disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}

.btn-switch-engine {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #4096FF 0%, #6CB8FF 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.btn-switch-engine::after {
  border: none;
}

.btn-switch-engine.disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}

.btn-reupload {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #FFFFFF;
  color: #333333;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #E5E5E5;
}

.btn-reupload::after {
  border: none;
}

.guide-link {
  padding: 16rpx 0;
}

.guide-link text {
  font-size: 26rpx;
  color: #576B95;
}

/* 重试次数 */
.retry-info {
  margin-top: 40rpx;
}

.retry-info text {
  font-size: 24rpx;
  color: #999999;
}

.retry-exceeded {
  color: var(--danger-color) !important;
}
