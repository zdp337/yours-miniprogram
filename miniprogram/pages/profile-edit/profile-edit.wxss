/* 个人信息编辑样式 — Yours·凝刻 */

.edit-page {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 24rpx 0;
}

.edit-section {
  background: #FFFFFF;
  margin-bottom: 24rpx;
}

.edit-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
}

.edit-label {
  font-size: 30rpx;
  color: #333333;
  flex-shrink: 0;
  margin-right: 32rpx;
}

.edit-value {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.avatar-preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 16rpx;
}

.arrow-sm {
  font-size: 28rpx;
  color: #CCCCCC;
}

.edit-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #333333;
}

.phone-display {
  font-size: 30rpx;
  color: #333333;
}

.bind-phone-btn {
  font-size: 26rpx;
  color: #FF6B35;
  background: none;
  border: none;
  padding: 0;
  line-height: 1;
}

.bind-phone-btn::after {
  border: none;
}

/* 保存按钮 */
.save-area {
  padding: 60rpx 32rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #333333;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  background: #CCCCCC;
  color: #FFFFFF;
}
