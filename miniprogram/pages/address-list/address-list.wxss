/* 收货地址列表样式 — Yours·凝刻 */

.address-page {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 160rpx;
}

/* 地址列表 */
.address-list {
  padding: 24rpx 32rpx;
}

.address-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.address-content {
  padding: 28rpx 32rpx;
}

.address-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.default-tag {
  background: #333333;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* 操作区 */
.address-actions {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
  padding: 0 32rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 20rpx 0;
  margin-right: 32rpx;
}

.action-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

.action-delete .action-text {
  color: #EE0A24;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
}

/* 新增按钮 */
.add-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: #333333;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.add-btn::after {
  border: none;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}
