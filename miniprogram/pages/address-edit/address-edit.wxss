/* 地址编辑样式 — Yours·凝刻 */

.address-edit-page {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 24rpx 0;
}

/* 表单 */
.form-section {
  background: #FFFFFF;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #333333;
  width: 160rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.form-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.region-text {
  font-size: 30rpx;
  color: #333333;
  margin-right: 8rpx;
}

.placeholder-text {
  font-size: 30rpx;
  color: #CCCCCC;
  margin-right: 8rpx;
}

.arrow-sm {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* 默认地址 */
.default-section {
  background: #FFFFFF;
  margin-bottom: 24rpx;
}

.default-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.default-label {
  font-size: 30rpx;
  color: #333333;
}

/* 按钮区 */
.btn-area {
  padding: 48rpx 32rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #333333;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 24rpx;
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  background: #CCCCCC;
}

.delete-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #FFFFFF;
  color: #EE0A24;
  font-size: 30rpx;
  border-radius: 48rpx;
  border: 2rpx solid #EE0A24;
}

.delete-btn::after {
  border: none;
}

/* 隐藏的 picker 触发器 */
.region-picker-trigger {
  position: fixed;
  left: -9999px;
  width: 0;
  height: 0;
}
