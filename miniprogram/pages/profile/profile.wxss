/* 个人中心样式 — Yours·凝刻 */

.profile-page {
  height: 100vh;
  background: var(--bg-color);
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #FFFFFF;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.scroll-area {
  height: 100vh;
  padding: 24rpx 32rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.user-avatar-wrap {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
}

.user-avatar-placeholder {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.phone-text {
  font-size: 24rpx;
  color: #666666;
}

.phone-bind-tip {
  font-size: 24rpx;
  color: #FF6B35;
}

.arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  flex-shrink: 0;
}

/* 通用卡片 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* 标题区 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.arrow-sm {
  font-size: 28rpx;
  color: #CCCCCC;
  margin-left: 4rpx;
}

/* 订单快捷入口 */
.order-shortcuts {
  display: flex;
  justify-content: space-around;
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.shortcut-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.shortcut-label {
  font-size: 22rpx;
  color: #666666;
}

/* 我的模型 */
.model-preview {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
}

.model-thumb {
  flex-shrink: 0;
}

.model-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.empty-model {
  padding: 24rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 功能列表 */
.func-list {
  padding: 0;
}

.func-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.func-item:last-child {
  border-bottom: none;
}

.func-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.func-label {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 退出登录 */
.logout-section {
  padding: 32rpx 0;
}

.logout-btn {
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #999999;
}
