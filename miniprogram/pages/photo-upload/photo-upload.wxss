/* 照片上传页样式 — Yours·凝刻 */

.upload-page {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 次数提示 */
.usage-bar {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 32rpx;
}

.usage-text {
  font-size: 26rpx;
  color: var(--accent-color);
  font-weight: 500;
}

/* 上传区域 */
.upload-section {
  padding: 0 32rpx 32rpx;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 440rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 3rpx dashed #CCCCCC;
  transition: all 0.3s;
}

.upload-area.disabled {
  border-color: #E5E5E5;
  background: #FAFAFA;
}

.upload-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F66 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.upload-icon-wrap.disabled-icon {
  background: linear-gradient(135deg, #E5E5E5 0%, #CCCCCC 100%);
}

.upload-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
}

.upload-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.upload-title.disabled-text {
  color: #999999;
}

.upload-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 历史照片 */
.history-section {
  padding: 0 32rpx 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.section-count {
  font-size: 24rpx;
  color: #999999;
}

.history-scroll {
  white-space: nowrap;
  width: 100%;
}

.history-list {
  display: inline-flex;
  gap: 16rpx;
}

.history-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  flex-shrink: 0;
}

.history-img {
  width: 160rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
}

.history-date {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 拍照指南入口 */
.guide-link {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.guide-link-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.guide-link-text {
  font-size: 26rpx;
  color: #576B95;
}

/* 底部选择面板 */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.action-sheet-mask.show {
  opacity: 1;
  visibility: visible;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s;
  z-index: 1000;
}

.action-sheet.show {
  transform: translateY(0);
}

.action-sheet-item {
  display: flex;
  align-items: center;
  padding: 32rpx 48rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.action-sheet-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.action-sheet-text {
  font-size: 32rpx;
  color: #333333;
}

.action-sheet-cancel {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  margin-top: 12rpx;
  border-top: 12rpx solid #F5F5F5;
}

.action-sheet-cancel text {
  font-size: 32rpx;
  color: #999999;
}
