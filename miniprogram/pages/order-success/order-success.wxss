/* 支付成功页样式 — Yours·凝刻 */

.success-page {
  min-height: 100vh;
  background: var(--bg-color);
  padding: var(--spacing-lg);
  padding-top: 80rpx;
}

/* 成功图标 */
.success-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.success-icon {
  font-size: 100rpx;
  margin-bottom: var(--spacing-md);
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* 订单信息 */
.order-info-card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.info-value.price {
  font-size: 30rpx;
  color: var(--accent-color);
  font-weight: 600;
}

/* 提示卡片 */
.tip-card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-xl);
  text-align: center;
}

.tip-emoji {
  font-size: 48rpx;
  display: block;
  margin-bottom: var(--spacing-sm);
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: var(--spacing-sm);
}

.tip-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 操作按钮 */
.action-area {
  margin-bottom: var(--spacing-xl);
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-round);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: var(--spacing-md);
}

.action-primary {
  background: var(--brand-color);
  color: #FFFFFF;
}

.action-secondary {
  background: var(--bg-white);
  color: var(--brand-color);
  border: 2rpx solid var(--border-color);
}

.action-link {
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: var(--spacing-sm) 0;
}

/* 分享 */
.share-area {
  text-align: center;
}

.share-divider {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.share-line {
  flex: 1;
  height: 1rpx;
  background: var(--border-color);
}

.share-text {
  font-size: 24rpx;
  color: var(--text-placeholder);
  padding: 0 var(--spacing-md);
}

.share-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: var(--spacing-md);
}

.share-btn {
  display: inline-block;
  background: var(--bg-white);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-round);
  padding: 12rpx 40rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}
