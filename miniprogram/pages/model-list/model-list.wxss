/* 我的模型列表页样式 */

.model-list-page {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 24rpx;
}

/* 使用量提示 */
.usage-bar {
  display: flex;
  justify-content: flex-end;
  padding: 0 8rpx 16rpx;
}

.usage-text {
  font-size: 24rpx;
  color: #999;
}

/* 模型网格 */
.model-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.model-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.model-card:active {
  transform: scale(0.98);
}

/* 图片区域 */
.card-image-wrap {
  width: 100%;
  aspect-ratio: 3 / 4;
  position: relative;
  overflow: hidden;
  background: #F5F5F5;
}

.card-image {
  width: 100%;
  height: 100%;
}

/* 生成中动画 */
.card-generating {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F0F0F0, #E8E8E8);
}

.gen-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E5E5;
  border-top-color: #333;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.gen-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.gen-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 失败态 */
.card-failed {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FFF5F5;
}

.fail-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.fail-text {
  font-size: 24rpx;
  color: #EE0A24;
}

/* 占位 */
.card-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ph-icon {
  font-size: 80rpx;
}

/* 信息区 */
.card-info {
  padding: 16rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-date {
  font-size: 22rpx;
  color: #999;
}

.card-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-dot.completed {
  background: #07C160;
}

.status-dot.generating,
.status-dot.queued {
  background: #FFB300;
  animation: pulse-dot 1.5s ease-in-out infinite;
}

.status-dot.failed {
  background: #EE0A24;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.status-text {
  font-size: 22rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.empty-btn {
  padding: 20rpx 56rpx;
  background: #333;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.empty-btn:active {
  opacity: 0.85;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-dot-group {
  display: flex;
  gap: 12rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: #999;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite;
}

.loading-dot:nth-child(1) { animation-delay: 0s; }
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
