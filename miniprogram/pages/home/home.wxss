/* 首页样式 — Yours·凝刻 */

.home-page {
  height: 100vh;
  background: var(--bg-color);
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #FFFFFF;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  letter-spacing: 2rpx;
}

/* 滚动区域 */
.scroll-area {
  height: 100vh;
}

/* Banner */
.banner-section {
  padding: 24rpx 32rpx 0;
}

.banner-swiper {
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  height: 100%;
  border-radius: 24rpx;
  display: flex;
  align-items: flex-end;
  padding: 40rpx;
}

.banner-1 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.banner-2 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 核心入口 */
.action-section {
  padding: 24rpx 32rpx;
}

.action-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8F66 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.action-icon {
  font-size: 44rpx;
}

.action-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999999;
}

.action-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  flex-shrink: 0;
}

/* 制作流程 */
.process-section {
  padding: 0 32rpx 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.process-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-num {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #333333;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.step-label {
  font-size: 22rpx;
  color: #666666;
  white-space: nowrap;
}

.step-line {
  width: 48rpx;
  height: 2rpx;
  background: #E5E5E5;
  margin: 0 8rpx;
  margin-bottom: 32rpx;
}

/* 精选展示 */
.showcase-section {
  padding: 0 32rpx 32rpx;
}

.showcase-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.showcase-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
}

.showcase-placeholder {
  height: 280rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecef 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  opacity: 0.3;
}

.showcase-label {
  display: block;
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
  color: #666666;
}

.showcase-tip {
  text-align: center;
  font-size: 24rpx;
  color: #CCCCCC;
  margin-top: 24rpx;
}
